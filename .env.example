# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cron y bot: en producción (Vercel) es obligatorio. Vercel inyecta Authorization: Bearer <CRON_SECRET> en crons si está definido.
# GitHub Actions (bot-cron.yml) debe usar el mismo valor en el secret del repositorio.
CRON_SECRET=

# Opcional: true = no ejecutar tareas de lib/cron-tasks (depósitos, premios, etc.) en ese proceso.
# SKIP_CRON=

# Seed local solo con: npm run dev + GET /api/seed-admin (nunca subas la contraseña al repo)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin

# Modo local: acceso sin login (REQUIRE_AUTH=false). En servidor pon true.
REQUIRE_AUTH=false
NEXT_PUBLIC_REQUIRE_AUTH=false
# Usuario usado cuando REQUIRE_AUTH=false (debe existir en BD; créalo con: npm run seed)
LOCAL_USER_EMAIL=albertonava@gmail.com

# Resend (PIN admin, recuperar contraseña, etc.) — https://resend.com
# RESEND_FROM debe usar un dominio que hayas verificado en Resend (ej. "FreeBoli <security@tudominio.com>").
RESEND_API_KEY=
# RESEND_FROM=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=genera-una-clave-secreta-min-32-chars
# Emails de administradores (separados por coma)
ADMIN_EMAILS=albertonava@gmail.com

# Google OAuth (ver LOCAL.md para pasos)
# Crea credenciales en: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Muestra el botón "Continuar con Google" (pon "true" cuando tengas ID y SECRET)
NEXT_PUBLIC_GOOGLE_ENABLED=false

# Microsoft OAuth (Azure AD - https://portal.azure.com)
AUTH_MICROSOFT_ID=
AUTH_MICROSOFT_SECRET=

# Wallet Solana del sitio (SOL + BOLIS) - NUNCA subir a Git
# Clave privada en base58 (ej. desde Phantom export)
SOLANA_WALLET_PRIVATE_KEY_BASE58=

# RPC Solana. El público suele no devolver historial (depósitos quedan en "Firmas: 0").
# Para que "Procesar depósitos" detecte BOLIS, usa un RPC con historial: Helius, QuickNode, Alchemy.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Cloudflare Turnstile (anti-bot). DORMIDO si se deja vacío: el código no cambia
# de comportamiento hasta que pegues AMBAS claves. Crea un widget en:
# https://dash.cloudflare.com/?to=/:account/turnstile
# - SECRET (servidor) y SITE KEY (cliente, pública).
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Retiros: días mínimos de antigüedad de cuenta para auto-pago on-chain.
# Cuentas más nuevas pasan a revisión manual (pending + flag de anomalía).
# AUTO_WITHDRAW_MIN_ACCOUNT_DAYS=3

# Configuración (opcional; si no, se usan valores por defecto en lib/config.ts)
# NEXT_PUBLIC_POINTS_PER_BOLIS=1000
# NEXT_PUBLIC_MIN_WITHDRAW_POINTS=10000
# NEXT_PUBLIC_FAUCET_POINTS=100
# NEXT_PUBLIC_FAUCET_COOLDOWN_HOURS=1
# NEXT_PUBLIC_MAX_SESSIONS_PER_IP=3
# NEXT_PUBLIC_AFFILIATE_COMMISSION_PERCENT=50
